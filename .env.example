# Template for local environment configuration.
# Copy to .env and fill in real values:  cp .env.example .env

# --- Logging ---
# Root log level: DEBUG | INFO | WARNING | ERROR. DEBUG shows the per-node trace.
LOG_LEVEL=INFO

# --- OpenAI ---
# Required. Used by the LLM nodes and by Weaviate's text2vec-openai vectorizer.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_MINI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.0

# --- PostgreSQL ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=mysecretpassword
POSTGRES_DATABASE=postgres
# Schema pinned on the connection search_path.
POSTGRES_SCHEMA=parking
# Connection pool: idle floor, hard cap, and seconds to wait for a free conn.
POSTGRES_POOL_MIN_SIZE=2
POSTGRES_POOL_MAX_SIZE=5
POSTGRES_POOL_TIMEOUT=5.0

# --- Weaviate ---
WEAVIATE_HOST=localhost
WEAVIATE_HTTP_PORT=8080
WEAVIATE_GRPC_PORT=50051

# --- Guardrails ---
GUARDRAIL_ENABLED=true
GUARDRAIL_INJECTION_CHECK=true
GUARDRAIL_SPACY_MODEL=en_core_web_sm
# Comma-separated PII labels.
GUARDRAIL_MASK_LABELS=PHONE,CREDIT_CARD,SSN,IP_ADDRESS
GUARDRAIL_BLOCK_INPUT_LABELS=CREDIT_CARD,SSN